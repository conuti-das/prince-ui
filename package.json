{
  "name": "prince-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Prince-Designsprache als gemeinsames React-Design-System (React Aria).",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "prince-ui": "workspace:*",
    "prince-ui-tokens": "workspace:*",
    "@internationalized/date": "3.12.2",
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/manager-api": "8.6.18",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@storybook/test": "^8.4.0",
    "@storybook/theming": "8.6.18",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-aria-components": "1.19.0",
    "react-dom": "^18.3.1",
    "storybook": "^8.4.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
